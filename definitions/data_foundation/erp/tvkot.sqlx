config {
  type: "operations",
  hasOutput: true,
  database: config.foundation.erp.targetProjectId,
  schema: config.foundation.erp.targetDatasetId,
  name: "tvkot",
  tags: ["sap", "common", "configuration", "yearly"]
}

js {
  const sap_cdc = require("includes/cortex/sap_cdc.js");
}

${sap_cdc.generateIncrementalMergeScript(ctx, {
  keys: [
  "mandt",
  "spras",
  "vkorg"
],
  columns: [
  "mandt",
  "spras",
  "vkorg",
  "vtext",
  "operation_flag",
  "is_deleted",
  "recordstamp"
],
  table_description: "Organizational Unit: Sales Organizations: Texts",
  column_descriptions: {
  "mandt": "Client (Mandant)",
  "spras": "Language Key",
  "vkorg": "Sales Organization",
  "vtext": "Name"
},
  target_ref: self(),
  source_ref: ref(config.foundation.erp.sourceDatasetId, "tvkot")
})}